# Disable directory listing for all directories.
Options -Indexes

# Servir WebAssembly con el MIME correcto (el escáner zxing-cpp usa un .wasm).
# Sin esto, algunos navegadores fallan al compilar el módulo por streaming.
<IfModule mod_mime.c>
    AddType application/wasm .wasm
</IfModule>

# Block direct HTTP access to sensitive directories.
# Any request whose URI starts with config/, lib/, sql/, or scripts/ is
# immediately rejected with 403 Forbidden. PHP is never invoked.
RewriteEngine On
RewriteRule ^(config|lib|sql|scripts)(/|$) - [F,L]

# Security headers — minimum-viable set for Fase 1.
# Full hardening (CSP, HSTS, Permissions-Policy) is deferred to Fase 7 once
# the full asset graph (Bootstrap, html5-qrcode, Service Worker) is known.
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "same-origin"
</IfModule>

# Permitir que el Service Worker (scan/sw.js) tome un scope más amplio que su
# carpeta (la raíz de la app), para poder cachear /assets/*.
<IfModule mod_headers.c>
    <FilesMatch "sw\.js$">
        Header set Service-Worker-Allowed "/"
        Header set Cache-Control "no-cache"
    </FilesMatch>
</IfModule>

# Block access to dotfiles (.env, .git, .htpasswd, etc.).
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block direct downloads of project manifest and dependency files.
<FilesMatch "(composer\.(json|lock)|package(-lock)?\.json|\.gitignore)$">
    Require all denied
</FilesMatch>

# =============================================================================
# Nginx equivalent (informational — Nginx ignores .htaccess)
# Apply the following in your Nginx server block when deploying to production.
# See also: config/nginx.conf.example
# =============================================================================
#
# location ~ ^/(config|lib|sql|scripts)(/|$) {
#     deny all;
#     return 404;
# }
#
# location ~ /\. {
#     deny all;
# }
#
# location ~ ^/(composer\.(json|lock)|package(-lock)?\.json)$ {
#     deny all;
# }
#
# add_header X-Frame-Options "DENY" always;
# add_header X-Content-Type-Options "nosniff" always;
# add_header Referrer-Policy "same-origin" always;
# =============================================================================
